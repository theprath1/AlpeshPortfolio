---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
import { credentials, principles, strengths } from '../data/siteData';
---

<BaseLayout title="About" description={`About ${SITE.name}, a technologist focused on scalable data and cloud systems.`}>
  <div class="page">

    <section class="page-intro reveal">
      <span class="eyebrow">About</span>
      <h1 class="page-title">A hands-on engineering leader with a platform-scale view.</h1>
      <p class="page-summary">
        I've spent 15+ years building and scaling cloud-native data platforms across streaming, analytics, AI/ML, and database engineering.
        The common theme is owning end-to-end data strategy with principal-level depth and executive-level accountability.
      </p>
    </section>

    <!-- Profile + Snapshot side by side -->
    <section class="split-layout reveal delay-1">
      <article class="hero-panel prose-note">
        <p class="mono-label">Profile</p>
        <p>
          My background spans petabyte-scale data lakes, real-time streaming pipelines, database architecture, and cloud-native platform delivery on AWS.
          I'm most effective where data strategy, platform reliability, and global team execution need to come together.
        </p>
        <p>
          I've built and operated multi-tenant platforms supporting 700K+ concurrent IoT devices, designed Kafka/Flink pipelines processing billions of events daily,
          and led enterprise modernization from on-prem systems to cloud-native analytics platforms.
        </p>
        <p>
          My approach combines staying deeply hands-on with driving FinOps discipline, data governance, security (ISO27001), and cross-functional alignment
          across product, AI/ML, SRE, and business stakeholders.
        </p>
      </article>

      <aside class="hero-side">
        <section class="info-card">
          <p class="mono-label">Snapshot</p>
          <ul class="bullet-list">
            <li><strong class="block mb-1 text-[var(--text)]">Primary strengths</strong><span>Data platform architecture, database engineering, streaming systems, and AI/ML infrastructure.</span></li>
            <li><strong class="block mb-1 text-[var(--text)]">Preferred problems</strong><span>Petabyte-scale platform design, multi-region compliance, and building globally distributed teams.</span></li>
            <li><strong class="block mb-1 text-[var(--text)]">Working style</strong><span>Hands-on architect who leads from the front while driving strategy, governance, and FinOps.</span></li>
          </ul>
        </section>
      </aside>
    </section>

    <!-- Credentials + Strengths -->
    <section class="two-column-grid reveal delay-2">
      <article class="section-card feature-card">
        <div class="section-heading">
          <h2>Credentials</h2>
          <p>Formal education and certifications that support the practical work.</p>
        </div>
        <div class="timeline-stack">
          {credentials.map((item) => (
            <div class="info-card">
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="section-card feature-card">
        <div class="section-heading">
          <h2>What I optimize for</h2>
          <p>Patterns that show up consistently in the way I lead projects and work with teams.</p>
        </div>
        <ul class="check-list">
          {strengths.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </section>

    <!-- Principles -->
    <section class="section reveal delay-3">
      <article class="cta-card">
        <p class="card-kicker">Operating principles</p>
        <h2>Standards are useful when they help teams move faster with fewer mistakes.</h2>
        <ul class="takeaway-list">
          {principles.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </section>

  </div>
</BaseLayout>
